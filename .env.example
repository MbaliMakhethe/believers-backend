# Database & cache
DATABASE_URL=postgres://postgres:postgres@localhost:5432/believers_wardrobe
REDIS_URL=redis://localhost:6379

# CORS — the unified Next.js site (storefront + vendor portal + admin
# panel all live at this one origin now). Medusa Admin's own built-in UI
# at :9000/app still works too if you ever want it, hence the second origin.
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:3000,http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:9000

JWT_SECRET=replace-with-a-long-random-string
COOKIE_SECRET=replace-with-a-long-random-string

# Stripe Connect — use your *platform* account's secret key here
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

MEDUSA_BACKEND_URL=http://localhost:9000
APP_URL=http://localhost:3000
